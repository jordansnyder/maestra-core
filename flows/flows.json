    {
        "id": "el_mqtt_in",
        "type": "mqtt in",
        "z": "tab_event_logger",
        "name": "All Maestra Events",
        "topic": "maestra/#",
        "qos": "0",
        "datatype": "utf8",
        "broker": "mqtt_broker_config",
        "nl": false,
        "rap": true,
        "rh": 0,
        "inputs": 0,
        "x": 150,
        "y": 200,
        "wires": [
            ["el_format_fn"]
        ]
    },
    {
        "id": "el_format_fn",
        "type": "function",
        "z": "tab_event_logger",
        "name": "Format Event",
        "func": "var topic = msg.topic;\nvar timestamp = new Date().toISOString();\n\n// Try to parse JSON payload\nvar data;\ntry {\n    data = typeof msg.payload === 'string' ? JSON.parse(msg.payload) : msg.payload;\n} catch(e) {\n    data = msg.payload;\n}\n\nmsg.payload = timestamp + ' | ' + topic + ' | ' + JSON.stringify(data).substring(0, 200);\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 390,
        "y": 200,
        "wires": [
            ["el_debug"]
        ]
    },
    {
        "id": "el_debug",
        "type": "debug",
        "z": "tab_event_logger",
        "name": "Event Log",
        "active": true,
        "tosidebar": true,
        "console": false,
        "tostatus": true,
        "complete": "payload",
        "targetType": "msg",
        "statusVal": "payload",
        "statusType": "auto",
        "x": 590,
        "y": 200,
        "wires": []
    },
    {
        "id": "el_comment",
        "type": "comment",
        "z": "tab_event_logger",
        "name": "How to use this flow",
        "info": "This flow captures ALL messages on the Maestra MQTT bus. Use this for debugging and understanding how messages flow through the system. Check the debug panel (sidebar > bug icon) to see events in real-time.\n\nThe wildcard subscription `maestra/#` matches every topic under the `maestra/` namespace, including:\n- Device heartbeats: `maestra/devices/+/heartbeat`\n- Entity state updates (inbound): `maestra/entity/state/update/<slug>`\n- Entity state broadcasts (outbound): `maestra/entity/state/<type>/<slug>`\n- Entity lifecycle: `maestra/entity/created/<type>/<slug>`, `maestra/entity/updated/...`, `maestra/entity/deleted/...`\n- Stream events: `maestra/stream/...`\n\nEach log line shows: timestamp | topic | payload (truncated to 200 chars).",
        "x": 160,
        "y": 100,
        "wires": []
    },

    {
        "id": "tab_show_control",
        "type": "tab",
        "label": "Show Control",
        "disabled": false,
        "info": "Listens for show state changes and logs them. Use this as a starting point for custom show control logic (e.g., trigger lighting cues, start audio, control projections based on show phase).",
        "env": []
    },
    {
        "id": "sc_mqtt_in",
        "type": "mqtt in",
        "z": "tab_show_control",
        "name": "Show State Changes",
        "topic": "maestra/entity/state/show_control/show",
        "qos": "0",
        "datatype": "auto",
        "broker": "mqtt_broker_config",
        "nl": false,
        "rap": true,
        "rh": 0,
        "inputs": 0,
        "x": 160,
        "y": 200,
        "wires": [
            ["sc_json_parse"]
        ]
    },
    {
        "id": "sc_json_parse",
        "type": "json",
        "z": "tab_show_control",
        "name": "Parse JSON",
        "property": "payload",
        "action": "",
        "pretty": false,
        "x": 380,
        "y": 200,
        "wires": [
            ["sc_extract_phase", "sc_debug"]
        ]
    },
    {
        "id": "sc_extract_phase",
        "type": "function",
        "z": "tab_show_control",
        "name": "Extract Phase",
        "func": "var data = msg.payload;\nvar phase = data.current_state ? data.current_state.phase : 'unknown';\nvar previousPhase = data.current_state ? data.current_state.previous_phase : null;\nmsg.phase = phase;\nmsg.previousPhase = previousPhase;\nmsg.payload = {\n    phase: phase,\n    previous_phase: previousPhase,\n    source: data.source || 'unknown',\n    timestamp: data.current_state ? data.current_state.transition_time : new Date().toISOString()\n};\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 580,
        "y": 200,
        "wires": [
            ["sc_switch"]
        ]
    },
    {
        "id": "sc_switch",
        "type": "switch",
        "z": "tab_show_control",
        "name": "Route by Phase",
        "property": "phase",
        "propertyType": "msg",
        "rules": [
            {"t": "eq", "v": "pre_show", "vt": "str"},
            {"t": "eq", "v": "active", "vt": "str"},
            {"t": "eq", "v": "paused", "vt": "str"},
            {"t": "eq", "v": "shutdown", "vt": "str"},
            {"t": "else"}
        ],
        "checkall": "false",
        "repair": false,
        "outputs": 5,
        "x": 780,
        "y": 200,
        "wires": [
            ["sc_preshow_debug"],
            ["sc_active_debug"],
            ["sc_paused_debug"],
            ["sc_shutdown_debug"],
            ["sc_other_debug"]
        ]
    },
