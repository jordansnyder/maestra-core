    {
        "id": "tab_device_monitor",
        "type": "tab",
        "label": "Device Monitor",
        "disabled": false,
        "info": "Monitors device heartbeats and displays activity in the debug panel.",
        "env": []
    },
    {
        "id": "dm_mqtt_in",
        "type": "mqtt in",
        "z": "tab_device_monitor",
        "name": "Device Heartbeats",
        "topic": "maestra/devices/+/heartbeat",
        "qos": "0",
        "datatype": "auto",
        "broker": "mqtt_broker_config",
        "nl": false,
        "rap": true,
        "rh": 0,
        "inputs": 0,
        "x": 140,
        "y": 200,
        "wires": [
            ["dm_json_parse"]
        ]
    },
    {
        "id": "dm_json_parse",
        "type": "json",
        "z": "tab_device_monitor",
        "name": "Parse JSON",
        "property": "payload",
        "action": "",
        "pretty": false,
        "x": 340,
        "y": 200,
        "wires": [
            ["dm_format_fn"]
        ]
    },
    {
        "id": "dm_format_fn",
        "type": "function",
        "z": "tab_device_monitor",
        "name": "Format Heartbeat",
        "func": "var data = msg.payload;\nvar deviceName = msg.topic.split('/')[2] || 'unknown';\nmsg.payload = {\n    device: deviceName,\n    status: data.data ? data.data.status : 'heartbeat',\n    timestamp: data.timestamp || new Date().toISOString()\n};\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 540,
        "y": 200,
        "wires": [
            ["dm_debug"]
        ]
    },
    {
        "id": "dm_debug",
        "type": "debug",
        "z": "tab_device_monitor",
        "name": "Device Activity",
        "active": true,
        "tosidebar": true,
        "console": false,
        "tostatus": true,
        "complete": "payload",
        "targetType": "msg",
        "statusVal": "payload.device",
        "statusType": "auto",
        "x": 750,
        "y": 200,
        "wires": []
    },
    {
        "id": "dm_comment",
        "type": "comment",
        "z": "tab_device_monitor",
        "name": "How to use this flow",
        "info": "This flow monitors device heartbeat messages. Deploy this flow and register a device to see heartbeats appear in the debug panel (sidebar \u2192 bug icon).\n\nHeartbeats arrive on `maestra/devices/+/heartbeat` where `+` is the device slug. The function node extracts the device name from the topic and formats a clean summary.",
        "x": 160,
        "y": 100,
        "wires": []
    },

    {
        "id": "tab_entity_controller",
        "type": "tab",
        "label": "Entity Controller",
        "disabled": false,
        "info": "Demonstrates controlling an entity's state via the Fleet Manager API and monitoring real-time state changes.",
        "env": []
    },
    {
        "id": "ec_inject_bright",
        "type": "inject",
        "z": "tab_entity_controller",
        "name": "Set Brightness to 100",
        "props": [
            {
                "p": "payload"
            }
        ],
        "repeat": "",
        "crontab": "",
        "once": false,
        "onceDelay": 0.1,
        "topic": "",
        "payload": "{\"brightness\":100}",
        "payloadType": "json",
        "x": 180,
        "y": 140,
        "wires": [
            ["ec_prepare_fn"]
        ]
    },
    {
        "id": "ec_inject_dim",
        "type": "inject",
