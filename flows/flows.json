    {
        "id": "ec_prepare_fn",
        "type": "function",
        "z": "tab_entity_controller",
        "name": "Prepare Request",
        "func": "// Wrap in the state update format\nmsg.payload = { state: msg.payload };\nmsg.headers = { \"Content-Type\": \"application/json\" };\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 420,
        "y": 200,
        "wires": [
            ["ec_http_req"]
        ]
    },
    {
        "id": "ec_http_req",
        "type": "http request",
        "z": "tab_entity_controller",
        "name": "Update Entity State",
        "method": "POST",
        "ret": "obj",
        "paytoqs": "ignore",
        "url": "http://fleet-manager:8080/entities/by-slug/gallery-light-1/state/update",
        "tls": "",
        "persist": false,
        "proxy": "",
        "insecureHTTPParser": false,
        "authType": "",
        "senderr": false,
        "headers": [],
        "x": 640,
        "y": 200,
        "wires": [
            ["ec_debug_resp"]
        ]
    },
    {
        "id": "ec_debug_resp",
