    {
        "id": "tab_event_logger",
        "type": "tab",
        "label": "Event Logger",
        "disabled": false,
        "info": "Captures and logs all messages flowing through the Maestra MQTT bus for debugging and system understanding.",
        "env": []
    },
    {
        "id": "el_mqtt_in",
        "type": "mqtt in",
        "z": "tab_event_logger",
        "name": "All Maestra Events",
        "topic": "maestra/#",
        "qos": "0",
        "datatype": "utf8",
        "broker": "mqtt_broker_config",
        "nl": false,
        "rap": true,
        "rh": 0,
        "inputs": 0,
        "x": 150,
        "y": 200,
        "wires": [
            ["el_format_fn"]
        ]
    },
    {
        "id": "el_format_fn",
        "type": "function",
        "z": "tab_event_logger",
        "name": "Format Event",
        "func": "var topic = msg.topic;\nvar timestamp = new Date().toISOString();\n\n// Try to parse JSON payload\nvar data;\ntry {\n    data = typeof msg.payload === 'string' ? JSON.parse(msg.payload) : msg.payload;\n} catch(e) {\n    data = msg.payload;\n}\n\nmsg.payload = timestamp + ' | ' + topic + ' | ' + JSON.stringify(data).substring(0, 200);\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 390,
        "y": 200,
        "wires": [
            ["el_debug"]
        ]
    },
    {
        "id": "el_debug",
        "type": "debug",
        "z": "tab_event_logger",
        "name": "Event Log",
        "active": true,
        "tosidebar": true,
        "console": false,
        "tostatus": true,
        "complete": "payload",
        "targetType": "msg",
        "statusVal": "payload",
        "statusType": "auto",
        "x": 590,
        "y": 200,
        "wires": []
    },
    {
        "id": "el_comment",
        "type": "comment",
        "z": "tab_event_logger",
        "name": "How to use this flow",
        "info": "This flow captures ALL messages on the Maestra bus. Use this for debugging and understanding how messages flow through the system. Check the debug panel (sidebar \u2192 bug icon) to see events in real-time.\n\nThe wildcard subscription `maestra/#` matches every topic under the `maestra/` namespace, including device heartbeats, entity state changes, stream events, and more.\n\nEach log line shows: timestamp | topic | payload (truncated to 200 chars).",
        "x": 160,
        "y": 100,
        "wires": []
    }
]
