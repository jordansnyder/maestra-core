    {
        "id": "dm_mqtt_in",
        "type": "mqtt in",
        "z": "tab_device_monitor",
        "name": "Device Heartbeats",
        "topic": "maestra/devices/+/heartbeat",
        "qos": "0",
        "datatype": "auto",
        "broker": "mqtt_broker_config",
        "nl": false,
        "rap": true,
        "rh": 0,
        "inputs": 0,
        "x": 140,
        "y": 200,
        "wires": [
            ["dm_json_parse"]
        ]
    },
    {
        "id": "dm_json_parse",
        "type": "json",
        "z": "tab_device_monitor",
        "name": "Parse JSON",
        "property": "payload",
        "action": "",
        "pretty": false,
        "x": 340,
        "y": 200,
        "wires": [
            ["dm_format_fn"]
        ]
    },
    {
        "id": "dm_format_fn",
        "type": "function",
        "z": "tab_device_monitor",
        "name": "Format Heartbeat",
        "func": "var data = msg.payload;\nvar deviceName = msg.topic.split('/')[2] || 'unknown';\nmsg.payload = {\n    device: deviceName,\n    status: data.data ? data.data.status : 'heartbeat',\n    timestamp: data.timestamp || new Date().toISOString()\n};\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 540,
        "y": 200,
        "wires": [
            ["dm_debug"]
        ]
    },
    {
        "id": "dm_debug",
        "type": "debug",
        "z": "tab_device_monitor",
        "name": "Device Activity",
        "active": true,
        "tosidebar": true,
        "console": false,
        "tostatus": true,
        "complete": "payload",
        "targetType": "msg",
        "statusVal": "payload.device",
        "statusType": "auto",
        "x": 750,
        "y": 200,
        "wires": []
    },
    {
        "id": "dm_comment",
        "type": "comment",
        "z": "tab_device_monitor",
        "name": "How to use this flow",
        "info": "This flow monitors device heartbeat messages arriving via MQTT. Deploy this flow and register a device to see heartbeats appear in the debug panel (sidebar > bug icon).\n\nHeartbeats arrive on `maestra/devices/+/heartbeat` where `+` is the device slug. MQTT-native devices (Arduino, ESP32) publish heartbeats directly to this topic. The function node extracts the device name from the topic and formats a clean summary.",
        "x": 160,
        "y": 100,
        "wires": []
    },

